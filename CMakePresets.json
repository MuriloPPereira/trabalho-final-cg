{
    "version": 6,
    "configurePresets": [
        {
            "name": "default-config",
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "GCC 15.2.0 x86_64-w64-mingw32 (ucrt64)",
            "displayName": "GCC 15.2.0 x86_64-w64-mingw32 (ucrt64)",
            "description": "Using compilers: C = C:\\msys64\\ucrt64\\bin\\gcc.exe, CXX = C:\\msys64\\ucrt64\\bin\\g++.exe",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "C:/msys64/ucrt64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/g++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default-build",
            "configurePreset": "default-config"
        },
        {
            "name": "build-run",
            "configurePreset": "default-config",
            "targets": [
                "run"
            ]
        }
    ],
    "workflowPresets": [
        {
            "name": "configure-build-run",
            "steps": [
                {
                    "type": "configure",
                    "name": "default-config"
                },
                {
                    "type": "build",
                    "name": "build-run"
                }
            ]
        }
    ]
}